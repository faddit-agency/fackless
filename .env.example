# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Kakao OAuth는 Supabase Dashboard > Authentication > Providers > Kakao 에서 설정합니다.
# 1. https://developers.kakao.com 에서 앱을 만들고 REST API 키와 카카오 로그인 활성화
# 2. Redirect URI: https://<supabase-project>.supabase.co/auth/v1/callback
# 3. Supabase Auth Providers > Kakao 에 Client ID / Client Secret 입력

# 패딧 외부 링크 (있는 경우)
NEXT_PUBLIC_FADDIT_URL=https://faddit.app
